# Copy to `.env` for local development (`npm run dev`).
# GitHub Pages: add the same key as a repository Actions secret for the workflow build.

# Google Cloud: API key with Google Sheets API enabled; restrict key by HTTP referrer where possible.
# Spreadsheet sharing must allow anyone with the link to view for key-only requests to succeed.
G_SHEETS_API_KEY=

# Optional: mimic GitHub Pages URL path when previewing locally (slash prefix and suffix required).
# VITE_BASE_PATH=/your-repo-name/
